    '     return [Send("worker", {"item": x})
    '             for x in state["items"]]
  }

  class interrupt_fn #FFE8E8 {
    ' interrupt() from langgraph.types
    ' Pauses graph execution, saves via checkpointer.
    ' Resume with Command(resume=value).
    ' DO NOT wrap in bare try/except.
