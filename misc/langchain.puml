' =============================================================================
' LANGGRAPH 1.0: FUNCTIONAL API
' =============================================================================
package "langgraph 1.0 - Functional API" #F5F0FF {

  class entrypoint_decorator <<(F,#7B2FBE)>> #F5F0FF {
    ' @entrypoint from langgraph.func
    ' Marks a function as a LangGraph entrypoint.
    ' Provides automatic checkpointing, streaming,
    ' and interrupt() without an explicit StateGraph.
    '
    ' @entrypoint(checkpointer=InMemorySaver())
    ' def my_agent(input: dict) -> dict:
    '     result = my_task(input["x"]).result()
    '     return {"output": result}
    +checkpointer: BaseCheckpointer
    +store: BaseStore
    ..returns..
    CompiledEntrypoint
  }

  class task_decorator <<(F,#7B2FBE)>> #F5F0FF {
    ' @task from langgraph.func
    ' Marks a function as a LangGraph task.
    ' Must be called from inside an @entrypoint.
    ' Returns a Future-like; call .result() to get value.
    '
    ' @task
    ' def my_task(x: int) -> int:
    '     return x * 2
    ' result = my_task(5).result()
    ..returns..
    Task
  }

  note as FuncAPINote
    Functional API vs Graph API:

    Functional API (@entrypoint + @task):
      Pythonic; plain functions, no state schema,
      no explicit nodes or edges. Best for
      linear or simple flows.

    Graph API (StateGraph):
      Explicit typed State, nodes, edges, reducers.
      Use when you need conditional routing,
      parallel branches, subgraphs, or fine-grained
      state control.

    Both fully support: checkpointing, streaming,
    interrupt(), human-in-the-loop, and BaseStore.
  end note
}

