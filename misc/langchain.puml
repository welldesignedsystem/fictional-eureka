package "langchain-core - Language Models" #E8F4FD {

  abstract class BaseLanguageModel #E8F4FD {
    -cache: BaseCache
    -callbacks: List
    {abstract} +generate_prompt()
    +invoke()
    +with_structured_output(schema)
  }

  abstract class BaseChatModel #E8F4FD {
    ' Primary model abstraction for all modern providers.
    ' BaseLLM (text-completion) is legacy/deprecated.
    +invoke()
    +stream()
    +batch()
    +bind_tools(tools)
    +with_structured_output(schema)
    {abstract} +_generate()
  }

  class init_chat_model <<(F,#FFD700)>> #E8F4FD {
    ' from langchain_core.language_models
    ' Provider-agnostic factory.
    ' e.g. init_chat_model("openai:gpt-4o")
    +model: str
    +model_provider: str
    +profile: Dict
    ..returns..
    BaseChatModel
  }
}

RunnableSerializable <|-- BaseLanguageModel
BaseLanguageModel <|-- BaseChatModel
init_chat_model ..> BaseChatModel : returns

