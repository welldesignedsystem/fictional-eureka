package "langchain 1.0 - Agent Middleware" #F0FFF0 {

  abstract class AgentMiddleware #F0FFF0 {
    ' from langchain.agents.middleware import AgentMiddleware
    '
    ' Override any combination of the 6 node-style hooks
    ' and 2 wrap-style hooks. All are OPTIONAL.
    '
    ' NODE-STYLE HOOKS (run at fixed points sequentially):
    '   Signature: (self, state: AgentState, runtime: Runtime)
    '   Return:    dict[str, Any] or None
    '   before_* -> first-to-last in middleware list
    '   after_*  -> last-to-first (reverse order)
    '
    ' WRAP-STYLE HOOKS (nested call stack):
    '   You call handler(request) yourself.
    '   Can retry, short-circuit, or transform.
    '   First middleware wraps all others.
    '
    ' Set state_schema to extend graph state.
    +state_schema: Type
    +before_agent(state: AgentState, runtime: Runtime): dict
    +before_model(state: AgentState, runtime: Runtime): dict
    +after_model(state: AgentState, runtime: Runtime): dict
    +after_agent(state: AgentState, runtime: Runtime): dict
    +wrap_model_call(request: ModelRequest, handler: Callable): ModelResponse
    +wrap_tool_call(request: ToolCallRequest, handler: Callable): ToolMessage
  }

  note as HookDecoratorsNote
    DECORATOR-BASED MIDDLEWARE (single-hook, no subclass):
    from langchain.agents.middleware import (
      before_agent, before_model,
      after_model,  after_agent,
      wrap_model_call, wrap_tool_call,
      dynamic_prompt,
    )

    @before_model(can_jump_to=["end"])
    def check_limit(state: AgentState, runtime):
        if len(state["messages"]) >= 50:
            return {"jump_to": "end"}
        return None

    @wrap_model_call
    def retry(request: ModelRequest, handler):
        for i in range(3):
            try: return handler(request)
            except: pass

    @dynamic_prompt
    def add_ctx(state: AgentState, runtime) -> str:
        return f"User: {runtime.context.user_id}"

    Decorators and class instances can be mixed
    freely in the middleware=[...] list passed to
    create_agent().
  end note

