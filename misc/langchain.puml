package "langchain-core - Tools" #E8F4FD {

  abstract class BaseTool #E8F4FD {
    -name: str
    -description: str
    -args_schema: Type[BaseModel]
    -return_direct: bool
    {abstract} +_run(*args, **kwargs)
    +run(tool_input)
    +arun(tool_input)
    +invoke()
  }

  class Tool #E8F4FD {
    -func: Callable
    +_run()
  }

  class StructuredTool #E8F4FD {
    -coroutine: AsyncCallable
    +_run()
    +from_function(func)
  }

  class tool_decorator <<(F,#FFD700)>> #E8F4FD {
    ' @tool decorator
    ' def my_fn(x: int) -> str:
    '   """docstring = description"""
    ' Wraps any function into a StructuredTool.
    ..returns..
    StructuredTool
  }

  class InjectedToolArgs #E8F4FD {
    ' from langchain_core.tools
    ' Type annotations for auto-injected params.
    ' Excluded from the LLM tool schema.
    '
    ' InjectedState  -> injects graph State
    ' InjectedStore  -> injects langgraph BaseStore
    ' InjectedToolArg-> generic injected param
    '
    ' @tool
    ' def my_tool(
    '   x: str,
    '   state: Annotated[State, InjectedState],
    '   store: Annotated[BaseStore, InjectedStore],
    ' ) -> str: ...
  }
}

