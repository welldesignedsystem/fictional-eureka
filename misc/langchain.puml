package "langgraph 1.0 - Graph Runtime" #F5F0FF {

  class StateGraph #F5F0FF {
    ' from langgraph.graph import StateGraph
    ' state_schema: TypedDict, dataclass, or Pydantic
    ' context_schema: optional runtime context type
    ' DEPRECATED: set_entry_point(), set_finish_point()
    ' Use add_edge(START,..) / add_edge(..,END) instead.
    -state_schema: Type
    -context_schema: Type
    +add_node(name, fn_or_subgraph, cache_policy)
    ' fn can be a plain function OR CompiledStateGraph
    +add_edge(start, end)
    +add_conditional_edges(source, path_fn, mapping)
    +compile(checkpointer, store, cache): CompiledStateGraph
  }

  class MessagesState #F5F0FF {
    ' from langgraph.graph import MessagesState
    ' Prebuilt TypedDict state for message-based agents.
    ' Equivalent to:
    '   class State(TypedDict):
    '     messages: Annotated[list[AnyMessage], add_messages]
    ' Subclass to extend:
    '   class MyState(MessagesState):
    '     documents: list[str]
    ' NOTE: MessageGraph is REMOVED in v1.0.
    ' Use StateGraph(MessagesState) instead.
    -messages: Annotated[list, add_messages]
  }

  class CompiledStateGraph #F5F0FF {
    ' Fully implements Runnable protocol.
    +invoke(input, config, context, recursion_limit)
    +stream(input, config, stream_mode)
    ' stream_mode: "values" or "updates" or "debug"
    '              or "messages" or "custom"
    +batch(inputs, config)
    +astream_events(input, version)
    +get_state(config): StateSnapshot
    +get_state_history(config): Iterator[StateSnapshot]
    +update_state(config, values)
  }

  class StateSnapshot #F5F0FF {
    ' Return type of get_state() and get_state_history().
    -values: Dict
    ' current state channel values
    -next: tuple
    ' node names to execute next
    -config: RunnableConfig
    ' includes checkpoint_id for time-travel
    -metadata: Dict
    -created_at: str
    -parent_config: RunnableConfig
    -tasks: tuple
    ' contains interrupt payloads if graph is paused
  }

  class ToolNode #F5F0FF {
    ' from langgraph.prebuilt import ToolNode
    ' Prebuilt graph node that executes tool calls.
    ' Reads AIMessage.tool_calls, runs tools in parallel,
    ' returns ToolMessages to state.
    -tools: List[BaseTool]
    -handle_tool_errors: bool or str or Callable
    ' True  = catch errors, return error ToolMessage
    ' False = let errors propagate
    ' str   = static error message
    +invoke(state, config)
  }

  class tools_condition_fn #F5F0FF {
    ' tools_condition from langgraph.prebuilt
    ' Standard conditional edge routing function.
    ' Returns "tools" if last message has tool_calls,
    ' else returns END.
    ' graph.add_conditional_edges("agent", tools_condition)
  }

  class Runtime #F5F0FF {
    ' from langgraph.runtime import Runtime
    ' Injected as 3rd arg to node functions when
    ' context_schema is set on the StateGraph.
    +context: ContextSchema
    +store: BaseStore
    +stream_writer: Callable
  }

  abstract class BaseCheckpointer #F5F0FF {
    ' from langgraph.checkpoint.base
    ' Thread-level (per-conversation) memory.
    ' Stores complete graph state snapshots per thread.
    ' thread_id MUST be in configurable.
    ' Add checkpoint_id for time-travel.
    {abstract} +get(config): Checkpoint
    {abstract} +put(config, checkpoint, metadata)
    +aget(config)
    +aput(config, checkpoint, metadata)
    +list(config): Iterator[CheckpointTuple]
  }

  class InMemorySaver #F5F0FF {
