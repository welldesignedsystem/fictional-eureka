' LANGGRAPH 1.0: GRAPH PRIMITIVES (Types + Constants)
' =============================================================================
package "langgraph 1.0 · Types & Primitives" #FFE8E8 {

  class "START / END" as StartEnd #FFE8E8 {
    ' from langgraph.graph import START, END
    ' Sentinel constants replacing the deprecated
    ' set_entry_point() / set_finish_point().
    '
    ' Usage:
    '   graph.add_edge(START, "first_node")
    '   graph.add_edge("last_node", END)
  }

  class Command #FFE8E8 {
    ' from langgraph.types import Command
    ' Combines state update + routing in one node return.
    ' Also used to resume after interrupt().
    -update: Dict          ' State keys to update
    -goto: str | List[str] ' Node(s) to route to next
    -graph: str            ' Command.PARENT = parent graph
    -resume: Any           ' Resume value for interrupt()
