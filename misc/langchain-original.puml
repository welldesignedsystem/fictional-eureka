package "langgraph 1.0 · Functional API" #F5F0FF {

  class "@entrypoint decorator" as entrypoint_dec <<(F,#7B2FBE)>> #F5F0FF {
    ' from langgraph.func import entrypoint
    ' Marks a Python function as a LangGraph entrypoint.
    ' Provides automatic checkpointing, streaming,
    ' and human-in-the-loop without explicit StateGraph.
    '
    ' Usage:
    '   @entrypoint(checkpointer=MemorySaver())
    '   def my_agent(input: dict) -> dict:
    '     result = my_task(input["x"]).result()
    '     return {"output": result}
    +checkpointer: BaseCheckpointer
    +store: BaseStore
    returns: CompiledEntrypoint
  }

  class "@task decorator" as task_dec <<(F,#7B2FBE)>> #F5F0FF {
    ' from langgraph.func import task
    ' Marks a Python function as a LangGraph task.
    ' Tasks run inside an @entrypoint and are
    ' automatically checkpointed. Calling a task
    ' returns a Future-like object; call .result().
    '
    ' Usage:
    '   @task
    '   def my_task(x: int) -> int:
    '     return x * 2
    '
    '   result = my_task(5).result()
    returns: Task
  }

  note as FuncAPINote
    Functional API vs Graph API:
    - Functional: Pythonic; plain functions with
      @entrypoint / @task decorators. No explicit
      state schema or node/edge definitions.
    - Graph API: Explicit StateGraph with nodes,
      edges, reducers, and typed State.
    Both support checkpointing, streaming,
    interrupt(), and human-in-the-loop.
    Choose Graph API when you need
    conditional routing, parallel branches,
    or subgraphs.
  end note
}

