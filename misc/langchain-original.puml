note bottom of create_agent_fn
  PRIMARY agent API in LangChain 1_0.
  Returns a CompiledStateGraph (LangGraph).
  agent = create_agent(
    model="openai:gpt-4o",
    tools=[search],
    middleware=[SummarizationMiddleware()],
  )
  result = agent.invoke({"messages": [...]})
end note

' =============================================================================
' LANGGRAPH 1_0: GRAPH RUNTIME
' =============================================================================
package "langgraph 1_0 · Graph Runtime" #F5F0FF {

  class StateGraph #F5F0FF {
    -state_schema: Type
    +add_node(name, fn)
    +add_edge(start, end)
    +add_conditional_edges(source, path_fn, mapping)
    +set_entry_point(key)
    +set_finish_point(key)
    +compile(checkpointer, store): CompiledStateGraph
  }

  class CompiledStateGraph #F5F0FF {
    ' Fully implements Runnable protocol
    +invoke(input, config)
    +stream(input, config)
    +batch(inputs, config)
    +astream_events(input, version)
    +get_state(config)
    +update_state(config, values)
    +get_state_history(config)
  }

  class MessageGraph #F5F0FF {
    ' Specialised StateGraph: state is List[BaseMessage]
  }

  class AgentState #F5F0FF {
    ' Default TypedDict state for create_react_agent
    -messages: List[BaseMessage]
    -structured_response: Any
  }

  abstract class BaseCheckpointer #F5F0FF {
    ' from langgraph.checkpoint.base
    {abstract} +get(config): Checkpoint
    {abstract} +put(config, checkpoint, metadata)
    +aget(config)
    +aput(config, checkpoint, metadata)
    +list(config)
  }

  class MemorySaver #F5F0FF {
    ' from langgraph.checkpoint.memory
    -storage: Dict
  }

  class SqliteSaver #F5F0FF {
    ' from langgraph.checkpoint.sqlite
    -conn: Connection
  }

  class PostgresSaver #F5F0FF {
    ' from langgraph.checkpoint.postgres
    -pool: ConnectionPool
  }

  abstract class BaseStore #F5F0FF {
    ' Cross-thread long-term memory
    ' from langgraph.store.base
    {abstract} +put(namespace, key, value)
    {abstract} +get(namespace, key)
    {abstract} +search(namespace_prefix)
    +delete(namespace, key)
  }

  class InMemoryStore #F5F0FF {
    ' from langgraph.store.memory
    -data: Dict
  }

  class "create_react_agent() [LG]" as LG_react <<(F,#7B2FBE)>> #F5F0FF {
    ' from langgraph.prebuilt import create_react_agent
    ' Lower-level: exposes full graph structure
    +model: BaseChatModel
    +tools: List[BaseTool]
    +state_schema: Type
    +checkpointer: BaseCheckpointer
    +store: BaseStore
    +prompt: str
    +response_format: Type[BaseModel]
    returns: CompiledStateGraph
  }
}

