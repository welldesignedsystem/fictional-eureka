note as PackageNote
  Modern install (v1.0):
    pip install langchain langchain-core
    pip install langchain-openai  (or langchain-anthropic, etc.)
    pip install langgraph
    pip install langgraph-checkpoint-sqlite   (optional)
    pip install langgraph-checkpoint-postgres (optional)

  Key import paths:
    Runnable / LCEL primitives  -> langchain_core.runnables
    Base model abstractions     -> langchain_core.language_models
    Messages                    -> langchain_core.messages
    Prompts                     -> langchain_core.prompts
    Output parsers              -> langchain_core.output_parsers
    Tools + @tool decorator     -> langchain_core.tools
    Injected tool args          -> langchain_core.tools (InjectedState etc.)
    Embeddings                  -> langchain_core.embeddings
    Retrieval                   -> langchain_core.retrievers
    Chat history                -> langchain_core.chat_history
    Callbacks                   -> langchain_core.callbacks
    Agents (high-level)         -> langchain.agents [create_agent]
    Graph API (low-level)       -> langgraph.graph [StateGraph]
    Functional API              -> langgraph.func [@entrypoint, @task]
    Prebuilt agent              -> langgraph.prebuilt [create_react_agent]
    Graph types/primitives      -> langgraph.types [Command, Send, interrupt]
    Runtime context             -> langgraph.runtime [Runtime]
    Managed state values        -> langgraph.managed [RemainingSteps]
    Checkpointers               -> langgraph.checkpoint.memory
                                   langgraph-checkpoint-sqlite (sep. pkg)
                                   langgraph-checkpoint-postgres (sep. pkg)
end note

' =============================================================================
' LANGCHAIN-CORE: RUNNABLE INTERFACE
' =============================================================================
package "langchain-core · Runnable Interface" #E8F4FD {

  abstract class Runnable #E8F4FD {
    +invoke(input, config)
    +batch(inputs, config)
    +stream(input, config)
    +ainvoke(input, config)
    +abatch(inputs, config)
    +astream(input, config)
    +bind(**kwargs)
    +with_config(config)
    +with_retry()
    +with_fallbacks(fallbacks)
    +pipe(other)
    +assign(**kwargs)
    +pick(keys)
  }

  abstract class RunnableSerializable #E8F4FD {
    +to_json()
    +configurable_fields(**kwargs)
  }

  class RunnableConfig #E8F4FD {
    ' Top-level keys (NOT nested in configurable):
    -tags: List[str]
    -metadata: Dict
    -callbacks: List
    -run_name: str
    ' recursion_limit is a top-level invoke() param,
    ' not stored here. Default = 1000 (v1.0.6+).
    ' Thread / memory config goes under:
    -configurable: Dict
    '   e.g. configurable={"thread_id": "abc"}
  }

  Runnable <|-- RunnableSerializable
}

' =============================================================================
' LANGCHAIN-CORE: LCEL STRUCTURAL RUNNABLES
' =============================================================================
package "langchain-core · Structural Runnables (LCEL)" #E8F4FD {

  class RunnableSequence #E8F4FD {
    -first: Runnable
    -middle: List[Runnable]
    -last: Runnable
    +invoke()
    +stream()
  }

  class RunnableParallel #E8F4FD {
    -steps: Dict[str, Runnable]
    +invoke()
    +batch()
  }

  class RunnableLambda #E8F4FD {
    -func: Callable
    +invoke()
    +as_tool()
  }

  class RunnablePassthrough #E8F4FD {
    +invoke()
    +assign(**kwargs)
  }

  class RunnableBranch #E8F4FD {
    -branches: List[Tuple[Runnable, Runnable]]
    -default: Runnable
    +invoke()
  }

  class RunnableWithFallbacks #E8F4FD {
    -runnable: Runnable
    -fallbacks: List[Runnable]
    +invoke()
  }

  class RunnableBinding #E8F4FD {
    -bound: Runnable
    -kwargs: Dict
    +invoke()
  }

  class RunnableWithMessageHistory #E8F4FD {
    ' Wraps any Runnable with per-session chat history.
    ' Useful for adding memory to LCEL chains
    ' without LangGraph.
    -runnable: Runnable
    -get_session_history: Callable[[str], BaseChatMessageHistory]
    -input_messages_key: str
    -history_messages_key: str
    +invoke(input, config)
    +stream(input, config)
  }
}

